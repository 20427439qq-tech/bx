rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function isFinance() {
      return isAuthenticated() && getUserData().role == 'finance';
    }
    
    function isAdmin() {
      return isAuthenticated() && (getUserData().role == 'admin' || request.auth.token.email == "20427439qq@gmail.com");
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'role']) &&
             data.uid is string && data.name is string &&
             data.role in ['employee', 'finance', 'admin'];
    }

    function isValidReimbursement(data) {
      return data.keys().hasAll(['userId', 'userName', 'totalAmount', 'status']) &&
             data.userId is string && data.userName is string &&
             data.totalAmount is number &&
             data.status in ['draft', 'pending', 'approved', 'rejected', 'returned'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    match /reimbursements/{reimbursementId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isFinance() || isAdmin());
      allow create: if isAuthenticated() && isValidReimbursement(request.resource.data) && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        (resource.data.userId == request.auth.uid && resource.data.status in ['draft', 'returned'] && isValidReimbursement(request.resource.data)) ||
        (isFinance() || isAdmin())
      );
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'draft';

      match /items/{itemId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated(); // Simplified for brevity, usually should check parent reimbursement ownership
      }
    }
  }
}
